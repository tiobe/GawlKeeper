impl unit GenCode

use

ScanIO. OpenInputs
UnixProcess. Exit, Failure, Success

import

GawlKeeper0
RuleChecker
RuleViolation

functions

root
Start()
{
  OpenInputs()
  if
    GawlKeeper0.EntryPoint()
  then
    Exit(Success)
  else
    Exit(Failure)
  fi
}

Eval(x : GawlKeeper) 
{
  RuleChecker.Check_GawlKeeper(x)
  RuleViolation.ShowViolations()
}
