impl unit GenCode

use

ScanIO. OpenInputs
UnixProcess. Exit, Failure, Success

import

Cyclox
GawlKeeper0
RuleChecker
RuleViolation

functions

root
Start()
{
  OpenInputs()
  if
    GawlKeeper0.EntryPoint()
  then
    Exit(Success)
  else
    Exit(Failure)
  fi
}

Eval(x : GawlKeeper) 
{
  if RuleChecker.IS_ENABLED then
    RuleChecker.Check_GawlKeeper(x)
    RuleViolation.ShowViolations()
  elsif Cyclox.IS_ENABLED then
    Cyclox.Cyclox(x)
  fi
}
