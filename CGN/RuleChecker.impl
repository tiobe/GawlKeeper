Check_FunctionCallParts(me : FunctionCallParts)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_CalleeList(me.callees)
  if me.paramsInit # NIL then
    Check_ParamsInitComma(me.paramsInit)
  fi
  if me.arguments # NIL then
    Check_Arguments(me.arguments)
  fi
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_CalleeList(me : CalleeList)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_CalleeExpression(me.callee.head)
  [
    {
      Check_String(",")
      Check_CalleeExpression(xxxcallee)
    }
  | xxxcallee : CalleeExpression <- Tail(me.callee, NIL)
  ]
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_CalleeExpression(me : AtomicCallee)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_InstrExpression(me.callee)
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_CalleeExpression(me : HashedCallee)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_InstrExpression(me.callee)
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Arguments(me : Arguments)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("(")
  Check_ArgumentsList(me.args)
  Check_String(")")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_ArgumentsList(me : ArgumentsList)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_ArgumentsAssignment(me.args.head)
  [
    {
      Check_String(",")
      Check_ArgumentsAssignment(xxxargs)
    }
  | xxxargs : ArgumentsAssignment <- Tail(me.args, NIL)
  ]
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_ParamsInitComma(me : ParamsInitComma)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("{")
  Check_ParamsInitListComma(me.params)
  Check_String("}")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_ParamsInitListComma(me : ParamsInitListComma)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_ArgumentsAssignment(me.args.head)
  [
    {
      Check_String(",")
      Check_ArgumentsAssignment(xxxargs)
    }
  | xxxargs : ArgumentsAssignment <- Tail(me.args, NIL)
  ]
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Identifier(me : Identifier)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_Ident(me.id)
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_StringLiteral(me : StringLiteral)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String(me.str)
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_PointerReference(me : PointerAccessHash)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_InstrExpression(me.hash)
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_PointerReference(me : PointerAccessReal)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String(me.real)
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Comment(si : SrcInfo)
{
  switch GetComments(si.pre_comment) {
  case comments : (List(Comment))
    last : Comment = Last(comments)

    [
      {
      }
    | comment : Comment <- comments
    , (IsComment(comment.string))
    ]
    LOC := last.pos + 1 + last.len
  else
    LOC := si.loc
  }
}

Check_String(s : String)
{
  LOC :+ #s
}

Check_Ident(id : Ident)
{
  LOC :+ #id
}
