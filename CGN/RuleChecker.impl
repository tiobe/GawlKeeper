impl unit RuleChecker

use 

print_support

Comments. Comment, GetComments
Rules
Syntactics. IsComment

global

IS_ENABLED : Bool := FALSE
LOC : Int := 0 

functions

Check_GawlKeeper(me : GawlKeeper)
{
  margin : Int := 0
  EvalComments()
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_Block(me.block_type)
  Rules.Check("C014", LOC, me.block_type)
  Rules.Check("C015", LOC, me)
  Rules.Check("G003", LOC, me)
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Block(me : DataBlock)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("DATA_BLOCK")
  Check_StringLiteral(me.block_name)
  Check_HeaderBlock(me.header)
  if me.non_retain then
    Check_String("NON_RETAIN")
  fi
  Check_DataForBlock(me.data)
  Check_String("BEGIN")
  [
    {
      Check_ArgumentsAssignment(xxxassignments)
      Check_String(";")
    }
  | xxxassignments : ArgumentsAssignment <- me.assignments
  ]
  Check_String("END_DATA_BLOCK")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Block(me : Function)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("FUNCTION")
  Check_StringLiteral(me.function_name)
  Check_String(":")
  Check_Type(me.return_type)
  Check_FunctionBody(me.body)
  Check_String("END_FUNCTION")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Block(me : FunctionBlock)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("FUNCTION_BLOCK")
  Check_StringLiteral(me.function_name)
  Check_FunctionBody(me.body)
  Check_String("END_FUNCTION_BLOCK")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Block(me : OrgBlock)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_StringLiteral(me.org_name)
  Check_FunctionBody(me.body)
  Check_String("END_ORGANIZATION_BLOCK")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Block(me : TypeBlock)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("TYPE")
  Check_StringLiteral(me.type_name)
  Check_HeaderBlock(me.header)
  Check_StructBlock(me.struct)
  Check_String(";")
  Check_String("END_TYPE")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_FunctionBody(me : FunctionBody)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_HeaderBlock(me.header)
  Rules.Check("C007", LOC, me)
  Rules.Check("C020", LOC, me)
  // TODO Can we shift the comments for each Field declaration
  // (and "END_VAR") to the previous element?
  [ { Check_LocalVarInputs(xxxinputs) }
  | xxxinputs : LocalVarInputs <- me.inputs
  ]
  if me.outputs # NIL then
    Check_String("VAR_OUTPUT")
    [ { Check_Field(xxxoutputs) }
    | xxxoutputs : Field <- me.outputs
    ]
    Check_String("END_VAR")
  fi
  if me.in_outs # NIL then
    // TODO Section 2.2.1 (pg. 13) of "Architectural design spec" says that
    // "In- and Output parameter may not be used"
    Check_String("VAR_IN_OUT")
    [ { Check_Field(xxxin_outs) }
    | xxxin_outs : Field <- me.in_outs
    ]
    Check_String("END_VAR")
  fi
  if me.locals # NIL then
    Check_String("VAR")
    [ { Check_Field(xxxlocals) }
    | xxxlocals : Field <- me.locals
    ]
    Check_String("END_VAR")
  fi
  if me.temps # NIL then
    Check_String("VAR_TEMP")
    [ { Check_Field(xxxtemps) }
    | xxxtemps : Field <- me.temps
    ]
    Check_String("END_VAR")
  fi
  Check_String("BEGIN")
  [ { Check_Network(xxxnetworks) }
  | xxxnetworks : Network <- me.networks
  ]
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_HeaderBlock(me : HeaderBlock)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Rules.Check("C001", LOC, me)
  Check_String(me.title)
  if me.params # NIL then
    Check_ParamsInitSemicolon(me.params)
  fi
  if me.author # NIL then
    Check_String("AUTHOR")
    Check_String(":")
    Check_InstrExpression(me.author)
  fi
  if me.family # NIL then
    Check_String("FAMILY")
    Check_String(":")
    Check_InstrExpression(me.family)
  fi
  if me.name # NIL then
    Check_String("NAME")
    Check_String(":")
    Check_InstrExpression(me.name)
  fi
  if me.version # NIL then
    Check_String("VERSION")
    Check_String(":")
    Check_String(me.version)
  fi
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_ParamsInitSemicolon(me : ParamsInitSemicolon)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("{")
  Check_ParamsInitListSemicolon(me.params)
  Check_String("}")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_ParamsInitListSemicolon(me : ParamsInitListSemicolon)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_ArgumentsAssignment(me.args.head)
  [
    {
      Check_String(";")
      Check_ArgumentsAssignment(xxxargs)
    }
  | xxxargs : ArgumentsAssignment <- Tail(me.args, NIL)
  ]
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_LocalVarInputs(me : LocalVarInputs)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("VAR_INPUT")
  if me.dbSpecf then
    Check_String("DB_SPECIFIC")
  fi
  [ { Check_Field(xxxinputs) }
  | xxxinputs : Field <- me.inputs
  ]
  Check_String("END_VAR")
  Check_Comment(me.src_info)
  set_margin(margin)
}

