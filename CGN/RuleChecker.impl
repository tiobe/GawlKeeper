}

Check_Field(me : Field)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_InstrExpression(me.name)
  Rules.Check("C014", LOC, me)
  if me.params # NIL then
    Check_ParamsInitSC(me.params)
  fi
  Check_String(":")
  Rules.Check("C042", LOC, me)
  Check_Type(me.type)
  if me.init # NIL then
    Check_Assignment(me.init)
  fi
  Check_String(";")
  Check_Comment(me.src_info)
  Rules.Check("G021", LOC, me)
  // TODO get the comment from the closure of the declarations block
  // (i.e. END_STRUCT or END_VAR)
  set_margin(margin)
}

Check_ParamsInitSC(me : ParamsInitSC)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("{")
  Check_ParamsInitListSC(me.params)
  Check_String("}")
  Check_Comment(me.src_info)
