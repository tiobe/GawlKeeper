  Check_String("END_STRUCT")
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Network(me : Network)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  Check_String("NETWORK")
  Rules.Check("G041", LOC, me)
  Check_String(me.title)
  Rules.Check("C006", LOC, me)
  Rules.Check("C011", LOC, me)
  Rules.Check("C030", LOC, me)
  Rules.Check("G026", LOC, me)
  Rules.Check("G043", LOC, me)
  [
    {
      if xxxinstructions # NIL then
        Check_Instruction(xxxinstructions)
      fi
      Check_String(";")
    }
  | xxxinstructions : Instruction <- me.instructions
  ]
  Check_Comment(me.src_info)
  set_margin(margin)
}

Check_Instruction(me : Instruction)
{
  margin : Int := 0
  Check_Comment(me.src_info)
  margin := fix_margin()
  if me.label # NIL then
    Check_Identifier(me.label)
    Check_String(":")
  fi
  Check_InstructionName(me.instruction)
  if me.arg # NIL then
    Check_InstrExpression(me.arg)
  fi
  Rules.Check("C030", LOC, me)
  Check_Comment(me.src_info)
  Rules.Check("G028", LOC, me)
  set_margin(margin)
}

