FUNCTION_BLOCK "FB_Dispatch_Point_T"
TITLE = %version: 5.09 % %Commit:  c3808b61 % CN: 50
{ S7_Optimized_Access := 'FALSE' }
FAMILY : Tubtrax
VERSION : 0.0
//Function:
//Dispatch point is used to assign carriers up to 15 different destinations using
//balance load criteria.
//
BEGIN
NETWORK
TITLE = aa: bad
      NOP 0;

// Copy section event DB number
      OPN "DB_Event_Section";

      L DBNO;
      T #t_DB_Event_Section;

NETWORK
TITLE = AAlso bad
      NOP 0;

// Copy section event DB number
      OPN "DB_Event_Section";

      L DBNO;
      T #t_DB_Event_Section;

NETWORK
TITLE = AA Too bad
      NOP 0;

// Copy section event DB number
      OPN "DB_Event_Section";

      L DBNO;
      T #t_DB_Event_Section;

NETWORK
TITLE = AA: Good
      NOP 0;

// Copy section event DB number
      OPN "DB_Event_Section";

      L DBNO;
      T #t_DB_Event_Section;

NETWORK
TITLE = AA:Not So Good
      NOP 0;

// Copy section event DB number
      OPN "DB_Event_Section";

      L DBNO;
      T #t_DB_Event_Section;

NETWORK
TITLE =
      NOP 0;

// Copy section event DB number
      OPN "DB_Event_Section";

      L DBNO;
      T #t_DB_Event_Section;

NETWORK
TITLE = CC: .
// Good enough. If the dot is removed, the trimming removes the blank space and
// thus the title is ill-formed.
      NOP 0;

// Copy section event DB number
      OPN "DB_Event_Section";

      L DBNO;
      T #t_DB_Event_Section;

NETWORK
TITLE = #Insert# // Insertion point code generator
      NOP 0;

NETWORK
TITLE = Example code

END_FUNCTION_BLOCK
