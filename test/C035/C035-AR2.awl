FUNCTION_BLOCK "FB_HBO_MV3D"
TITLE = %version: 5.18 % %Commit:  % CN: 41
{ S7_Optimized_Access := 'FALSE' }
FAMILY : General
VERSION : 0.0
//Function:
//Handle all data handovers with the MV3D screening machine and detect/log errors
//in the process.
//
//
//SOURCE
//%Project:      %
//%Repo:         %
//%Commit:       %
//%DateTimeUTC:  %
//
//%HISTORY%
//Issue:        Commit:  Date:      Version: Author:              Description:
//------------- -------- ---------- -------- -------------------- -------------------------------------------------------------------------------
