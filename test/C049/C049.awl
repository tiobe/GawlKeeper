   VAR_TEMP 
      t_DB_Num_PLT : Int;   // Number of the PLT DB
      t_Num_Items_Found : Int;   // Number of items found during search.
      t_Not_Used : Int;   // Not used integer
      t_TRS01_IO_Available : Bool;   // CMD: Signal for indication IO is OK (no Fieldbus or IO error)
      t_TRS02_IO_Available : Bool;   // CMD: Signal for indication IO is OK (no Fieldbus or IO error)
      t_TRS03_IO_Available : Bool;   // CMD: Signal for indication IO is OK (no Fieldbus or IO error)
      t_TRS04_IO_Available : Bool;   // CMD: Signal for indication IO is OK (no Fieldbus or IO error)
      t_TRS01_Motor_Run : Bool;   // CMD: Signal motor run
      t_TRS02_Motor_Run : Bool;   // CMD: Signal motor run
      t_TRS03_Motor_Run : Bool;   // CMD: Signal motor run
      t_TRS04_Motor_Run : Bool;   // CMD: Signal motor run
      t_Dwnstr_Not_RTR : Bool;   // Downstream section is not Ready to Receive
      t_Item_at_Handover : Bool;   // Item at handover from PLT DB
   END_VAR


BEGIN
NETWORK
TITLE = AA: Transport section TRS01
// TB08 - Twin Belt - LMS-V_1-dir_1-speed_PEC-EOS
      NOP 0;

// Create IO Available signal
      A #i_IO_Available;
      AN #s_TRS01.ST_LMS_NotPrsnt;
      AN #s_TRS01.ST_LMS_Err;
      = #t_TRS01_IO_Available;

// Equipment layer - PEC

      CALL #s_TRS01_FB_EQP_PEC_EOS
      (  i_Setting                   := #i_TRS01_Setting.PEC_1 , 
         i_DB_PLT                    := #i_TRS01_DB_PLT , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_Dwnstr_PLT_Pos            := 0 , 
         i_CFG_Blockage_Length       := #i_CFG_Blockage_Length , 
         i_CFG_Delay_On_Filter       := 15 , 
         i_CFG_Delay_Off_Filter      := 0 , 
         i_CFG_Flickering_Length     := 60 , 
         i_CFG_Min_Product_Length    := 60 , 
         i_CFG_Preset_PEC_Latch      := #s_TRS01.ST_LMS_Not_Auto , 
         i_CFG_Track_Present         := TRUE , 
         i_CFG_Reset_Block_PEC_Oc    := FALSE , 
         i_IO_NOT_PEC                := #i_TRS01_IO_NOT_EOS_PEC , 
         i_Eqp_Available_IO          := #t_TRS01_IO_Available , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         o_LPOS                      := #s_TRS01.LPOS , 
         o_PEC_Position              := #s_TRS01.PEC_Position , 
         o_ST_PEC_Blk                := #s_TRS01.ST_EOS_PEC_Blk
      );

// Condition to request stop
      A #s_TRS01.ST_LMS_NotPrsnt;
      O #s_TRS01.ST_LMS_Err;
      O #s_TRS01.ST_LMS_Not_Auto;
      O #s_TRS01.ST_LMS_Not_Hthy;
      O #s_TRS01.ST_EOS_PEC_Blk;
      O #s_TRS01.ST_EOS_PEC_Miss;
      O(;
      O #s_TRS02.Ext_Req_Stop;
      O #s_TRS03.Ext_Req_Stop;
      O #s_TRS04.Ext_Req_Stop;
      A #o_TRS01_ST_Started;
      );
      = #s_TRS01.Ext_Req_Stop;

//Check RTR from the downstream section.
      OPN #i_TRS_Dwnstr_DB_PLT;
      AN %DBX10.4;//Section Available
      ON %DBX10.5;//Section operational
      ON %DBX10.3;//Cascade
      = #t_Dwnstr_Not_RTR;

      A %DBX10.6;//Item in handover
      AN %DBX10.1;//Section run
      O %DBX11.0;//Or inhibit receive
      S #t_Dwnstr_Not_RTR;

// Equipment Layer - Basic

      CALL #s_TRS01_FB_EQP_Basic
      (  i_ID_Section                := #i_TRS01_ID , 
         i_Basic_Offset              := #i_TRS01_Setting.Basic.Offset , 
         i_DB_PLT                    := #i_TRS01_DB_PLT , 
         i_DB_PLT_DwnStr             := #i_TRS02_DB_PLT , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_Conveyor_Speed            := #s_TRS01.Select_Conveyor_Speed , 
         i_Run_Out_Distance          := #s_TRS01.Select_Run_Out_Dist , 
         i_Start_Up_Distance         := #s_TRS01.Select_Started_Up_Dist , 
         i_Minimum_Gap               := #i_TRS01_Setting.Basic.Minimum_Gap , 
         i_Add_Gap_Stop              := #i_TRS01_Setting.Basic.Add_Gap_Stop , 
         i_Minimum_H2H               := #i_TRS01_Setting.Basic.Minimum_H2H , 
         i_Add_H2H_Stop              := #i_TRS01_Setting.Basic.Add_H2H_Stop , 
         i_CFG_Cascade_Delay_Time    := 340 , 
         i_CFG_Strt_Up_T_E_Save      := 90 , 
         i_CFG_Run_Out_E_Save        := 20 , 
         i_CFG_Stop_T_E_Save         := 130 , 
         i_PPI_Displacement          := 0 , 
         i_Dwnstr_PLT_Pos            := #s_TRS01.PEC_Position , 
         i_CFG_Disbl_E_Save          := "DB_Setting".common.Disable_Energy_Saving , 
         i_CFG_Slave_Mode            := FALSE , 
         i_CFG_Del_Window_Codes      := FALSE , 
         i_Available_IO              := #i_IO_Available , 
         i_Safety_OK                 := #i_Safety_OK , 
         i_CMD_Enable                := #i_CMD_Enable , 
         i_CMD_Start                 := #i_CMD_Start , 
         i_Ext_Req_Stop              := #s_TRS01.Ext_Req_Stop , 
         i_Ext_Req_Halt              := #t_Dwnstr_Not_RTR , 
         i_OS_Direction_Change       := FALSE , 
         i_Clr_PLT_Data              := #s_TRS01.ST_LMS_Not_Auto , 
         o_External                  := #o_TRS01_Ext_Outputs , 
         o_Motor_Run                 := #t_TRS01_Motor_Run , 
         o_ST_Items                  := #o_TRS01_ST_Items , 
         o_ST_Running                := #o_TRS01_ST_Running , 
         o_ST_Started                := #o_TRS01_ST_Started , 
         o_ST_Request_Halt           := #o_TRS01_ST_Req_Halt , 
         o_ST_Request_Stop           := #o_TRS01_ST_Req_Stop , 
         o_ST_External_Stop          := #o_TRS01_ST_Ext_Stop , 
         o_Ready_To_Restart          := #s_TRS01.Ready_To_Restart
      );

// Update Layer - TRK_Update

      CALL #s_TRS01_FB_TRK_Update_EOS
      (  i_Setting                   := #i_TRS01_Setting.Tracking , 
         i_DB_PLT                    := #i_TRS01_DB_PLT , 
         i_Event_DB                  := "DB_Event_Section" , 
         i_Position_PEC_Update       := #s_TRS01.PEC_Position , 
         i_LPOS                      := #s_TRS01.LPOS , 
