FUNCTION_BLOCK "FB_ACZ01_T"
TITLE = %version: 5.13 % %Commit:  c3808b61 % CN: 55
{ S7_Optimized_Access := 'FALSE' }
FAMILY : Tubtrax
VERSION : 0.0
//Function:
//Acceleration Zone, accelerates the items over the zone to a higher speed
//
//
//SOURCE
//%Project:      allcttt %
//%Repo:         a_ttt %
//%Commit:       c3808b61 %
//%DateTimeUTC:  2023-12-11T14:59:55 %
//
//%HISTORY%
//Issue:        Commit:  Date:      Version: Author:              Description:
//------------- -------- ---------- -------- -------------------- ------------------------------------------------------------------------------------------------
//ALLCTTT-4059  c3808b61 2023-12-11 5.13     Pascal van Kempen    Added history table
//ALLCTTT-4042  55fd833f 2023-12-05 5.12     Henri de Leijer      First step to remove the library files
//ALLCTTT-2667  dbcac36d 2022-11-14 5.11     Damayanti Bhapkar    Added statuses for fieldbus slaves
//ALLCTTT-2480  56dd7140 2022-09-29 5.10     Henri de Leijer      ALLCTTT-2480 IC DCZ HSZ ACZ combination often in energy save while items present on upstream TRZ
//ALLCTTT-632   38df93ee 2022-01-06 5.09     Damayanti Bhapkar    Updated status PEC bad tracking for position tracking
//ALLCTTT-906   72a9e833 2021-04-21 5.08     Henri de Leijer      Added temp definition & code line update
//ALLCTTT-906   28c6d529 2021-04-16 5.07     Henri de Leijer      When ACZ has items and no error, then trigger the downstream section out of E-save.
//ALLCTTT-272   544e4e84 2020-12-10 5.06     Pascal van Kempen    removed keywords
//ALLCTTT-272   9d531fbf 2020-12-10 5.05     Pascal van Kempen    Revert corrected checkin sequence for determining version information properly
//ALLCTTT-272   ae3fa862 2020-12-10 5.04     Pascal van Kempen    corrected checkin sequence for determining version information properly
//ALLCTTT-272   5a1edb78 2020-12-10 5.03     Pascal van Kempen    Revert keywords updates
//ALLCTTT-272   8d62c219 2020-12-10 5.02     Pascal van Kempen    keywords updates
//ALLCTTT-272   31a64871 2020-12-10 5.01     Pascal van Kempen    initial import
//
//Modification History:                                 By:      Date:     Rev:
//----------------------------------------------------  -------  --------  -----
//ra#37889: i_CFG_PLC_Log_Route_Msgs = FALSE            inas12   13-08-20   2.07
//ra#35423: i_CFG_Flickering_length = 60                inas12   22-07-20   2.06
//ra#36116: Update setting UDTs                         nldmaa   17-07-20   2.05
//ra#36061: i_CFG_Motor_Switch_Time = 0	                nlsnaw   19-03-20   2.04
//ra#35474: HighSpeed Update speed profiles ACZ, DCZ    nlHdL    12-11-19   2.03
//ra#35010: ACZ and DCZ Ready to restart signal update  nlHdL    25-09-19   2.02
//Initial version                                       nlHdL    26-08-19   2.01
//
//Description:
//The primary function of the ACZ is to provide an interface between 
//regular 2 m/s speed and HSZs, which run at much higher speeds.
//
//   TRS01      TRS02        TRS03         TRS04
// |--------| |--------| |-----------| |-----------|
// |        | |        | |           | |           |
// |--------| |--------| |-----------| |-----------|
   VAR_INPUT 
      i_CMD_Enable : Bool;   // CMD: Enable command
      i_CMD_Start : Bool;   // CMD: Start command
      i_CMD_Reset : Bool;   // CMD: Reset command
      i_IO_Available : Bool;   // IO is OK signal (no fieldbus or IO error)
      i_Safety_OK : Bool;   // Safety is OK signal
      i_Send_Statistics : Bool;   // Trigger send and clear statistics
      i_CFG_Blockage_Length : Int := 500;   // CFG: [cm] Delay for detecting a PEC blockage
      i_DB_PLT_Lost_And_Found : DB_ANY := DB1;   // Data Structure: DB PLT lost & found buffer
      i_TRS_Dwnstr_DB_PLT : DB_ANY := DB1;   // Data Structure: DB PLT
      i_TRS01_ID : DWord;   // ID Record HEX AAAAZZSS/OO
      i_TRS01_Setting : "UDT_TRS_T1D2S1P_Sett";   // Data Structure: Setting
      i_TRS01_CFG_LMS_In_Hardw_ID : HW_ANY;   // CFG: Hardware ID of the module from which the data is to be read
      i_TRS01_CFG_LMS_Out_Hardw_ID : HW_ANY;   // CFG: Hardware ID of the module to which the data is to be written
      i_TRS01_DB_PLT : DB_ANY := DB1;   // Data Structure: DB PLT
      i_TRS01_LMS_Not_Prsnt : Bool;   // LMS ASi slave is not present
      i_TRS01_LMS_Error : Bool;   // LMS ASi slave has an error
      i_TRS01_IO_LMS_Auto : Bool;   // HW: Automatic signal from LMS
      i_TRS01_IO_LMS_Healthy : Bool;   // HW: Healthy signal from LMS
      i_TRS01_IO_NOT_EOS_PEC : Bool;   // HW: End Of Section PEC (TRUE = No product detected)
      i_TRS02_ID : DWord;   // ID Record HEX AAAAZZSS/OO
      i_TRS02_Setting : "UDT_TRS_T1D2S1P_Sett";   // Data Structure: Setting
      i_TRS02_CFG_LMS_In_Hardw_ID : HW_ANY;   // CFG: Hardware ID of the module from which the data is to be read
      i_TRS02_CFG_LMS_Out_Hardw_ID : HW_ANY;   // CFG: Hardware ID of the module to which the data is to be written
      i_TRS02_DB_PLT : DB_ANY := DB1;   // Data Structure: DB PLT
      i_TRS02_LMS_Not_Prsnt : Bool;   // LMS ASi slave is not present
      i_TRS02_LMS_Error : Bool;   // LMS ASi slave has an error
      i_TRS02_IO_LMS_Auto : Bool;   // HW: Automatic signal from LMS
      i_TRS02_IO_LMS_Healthy : Bool;   // HW: Healthy signal from LMS
      i_TRS02_IO_NOT_EOS_PEC : Bool;   // HW: End Of Section PEC (TRUE = No product detected)
      i_TRS03_ID : DWord;   // ID Record HEX AAAAZZSS/OO
      i_TRS03_Setting : "UDT_TRS_T1D2S1P_Sett";   // Data Structure: Setting
      i_TRS03_CFG_LMS_In_Hardw_ID : HW_ANY;   // CFG: Hardware ID of the module from which the data is to be read
      i_TRS03_CFG_LMS_Out_Hardw_ID : HW_ANY;   // CFG: Hardware ID of the module to which the data is to be written
      i_TRS03_DB_PLT : DB_ANY := DB1;   // Data Structure: DB PLT
      i_TRS03_LMS_Not_Prsnt : Bool;   // LMS ASi slave is not present
      i_TRS03_LMS_Error : Bool;   // LMS ASi slave has an error
      i_TRS03_IO_LMS_Auto : Bool;   // HW: Automatic signal from LMS
      i_TRS03_IO_LMS_Healthy : Bool;   // HW: Healthy signal from LMS
      i_TRS03_IO_NOT_EOS_PEC : Bool;   // HW: End Of Section PEC (TRUE = No product detected)
