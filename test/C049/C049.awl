         o_ST_PEC_Miss               := #s_TRS01.ST_EOS_PEC_Miss
      );

// Hardware Layer - LMS Multispeed

      AN "M_Hardware_PN";
      JCN AA01;

      CALL #s_TRS01_FB_HW_MltSpd_LMS
      (  i_CMD_Send_Stat             := #i_Send_Statistics , 
         i_DB_PLT                    := #i_TRS01_DB_PLT , 
