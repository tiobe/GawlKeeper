         i_CMD_Req_Motor_Run         := #t_TRS01_Motor_Run , 
         o_IO_MTR_Fwd                := #o_TRS01_IO_MTR_Fwd , 
         o_IO_MTR_Rev                := #o_TRS01_IO_MTR_Rev , 
         o_IO_Speed_Select1          := #o_TRS01_IO_Speed_Select1 , 
         o_IO_Speed_Select2          := #o_TRS01_IO_Speed_Select2 , 
         o_ST_ASI_NotPrsnt           := #s_TRS01.ST_LMS_NotPrsnt , 
         o_ST_ASI_Err                := #s_TRS01.ST_LMS_Err , 
         o_ST_LMS_Not_Auto           := #s_TRS01.ST_LMS_Not_Auto , 
         o_ST_LMS_Not_Hthy           := #s_TRS01.ST_LMS_Not_Hthy , 
         o_Select_Conveyor_Speed     := #s_TRS01.Select_Conveyor_Speed , 
         o_Select_Run_Out_Dist       := #s_TRS01.Select_Run_Out_Dist , 
         o_Select_Started_Up_Dist    := #s_TRS01.Select_Started_Up_Dist
      );

      JU AA02;

AA01:      CALL #s_TRS01_FB_HW_MTR_PN_LMS
      (  i_CMD_Send_Stat             := #i_Send_Statistics , 
         i_DB_PLT                    := #i_TRS01_DB_PLT , 
         i_Event_DB                  := "DB_Event_Section" , 
         i_Speed                     := #i_TRS01_Setting.Hardware.Speed2 , 
         i_Run_Out_Dist              := #i_TRS01_Setting.Hardware.Speed2_Run_Out_Dist , 
         i_Start_Up_Dist             := #i_TRS01_Setting.Hardware.Speed2_Start_Up_Dist , 
         i_CFG_Motor_Switch_Time     := 0 , 
         i_CFG_In_Hardw_ID           := #i_TRS01_CFG_LMS_In_Hardw_ID , 
         i_CFG_Out_Hardw_ID          := #i_TRS01_CFG_LMS_Out_Hardw_ID , 
         i_Available_IO              := #i_IO_Available , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         i_CMD_Req_Motor_Run         := #t_TRS01_Motor_Run , 
         o_ST_FieldB_NotPrsnt        := #s_TRS01.ST_LMS_NotPrsnt , 
         o_ST_FieldB_Error           := #s_TRS01.ST_LMS_Err , 
         o_ST_LMS_Not_Auto           := #s_TRS01.ST_LMS_Not_Auto , 
         o_ST_LMS_Not_Hthy           := #s_TRS01.ST_LMS_Not_Hthy , 
         o_Select_Conveyor_Speed     := #s_TRS01.Select_Conveyor_Speed , 
         o_Select_Run_Out_Dist       := #s_TRS01.Select_Run_Out_Dist , 
         o_Select_Started_Up_Dist    := #s_TRS01.Select_Started_Up_Dist
      );

AA02:      NOP 0;

// If downstream not available stop the infeed flow

      OPN #i_TRS01_DB_PLT;
      A #t_Dwnstr_Not_RTR;
      = %DBX11.0;
      R %DBX10.3;//Reset cascade

      L %DBW6;//Read upstream PLT DB
      T #t_DB_Num_PLT;// Determine PLT block DB number
      L 1;
      >I;// Check if upstream is valid PLT DB
      JCN AA03;

      OPN DB[ #t_DB_Num_PLT];

      A %DBX10.6;//Read item at handover from upstream PLT
      = #t_Item_at_Handover;

// Data Layer

AA03:      CALL #s_TRS01_FB_DAT_T
      (  i_ID                        := #i_TRS01_ID , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_DB_PLT_Lost_And_Found     := "DB_PLT_Lost_Found_T"
      );

// Data Layer

      CALL #s_TRS01_FB_DAT
      (  i_ID_Section                := #i_TRS01_ID , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_PLC_Log_FIFO_DB           := "DB_LOG_Event_FIFO" , 
         i_CFG_BPI_Log_Level         := "DB_Setting".common.External_Log_Level , 
         i_CFG_PLC_Log_Level         := "DB_Setting".common.Internal_Log_Level , 
         i_CFG_PLC_Log_Route_Msgs    := FALSE
      );

