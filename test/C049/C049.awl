      s_TRS04_FB_DAT_T : "FB_DAT_T";   // Block call static FB_DAT_T
      s_TRS04_FB_DAT : "FB_DAT";   // Block call static FB_DAT
      s_TRS01 : Struct
         LPOS : Int;   // Real position of the bag for tracking layer
         PEC_Position : Int;   // [cm] position of the physical PEC
         Select_Conveyor_Speed : Int;   // [mm/s] Selected conveyor speed
         Select_Run_Out_Dist : Int;   // [cm] Selected run out distance of this speed
         Select_Started_Up_Dist : Int;   // [cm] selected start up distance of this speed
         ST_LMS_NotPrsnt : Bool;   // ST: LMS slave not present
         ST_LMS_Err : Bool;   // ST: LMS slave error
         ST_LMS_Not_Auto : Bool;   // ST: The local motor starter is reporting not Automatic
         ST_LMS_Not_Hthy : Bool;   // ST: The local motor starter is reporting not Healthy
         ST_EOS_PEC_Blk : Bool;   // ST: PEC blockage
         ST_EOS_PEC_Miss : Bool;   // ST: PEC successive missings
         Ext_Req_Stop : Bool;   // Request signal from external to stop (restart needed)
         Ready_To_Restart : Bool;   // Ready To Restart to system control
      END_STRUCT;
      s_TRS02 : Struct
         LPOS : Int;   // Real position of the bag for tracking layer
         PEC_Position : Int;   // [cm] position of the physical PEC
