// Update Layer - TRK_Update

      CALL #s_TRS03_FB_TRK_Update_EOS
      (  i_Setting                   := #i_TRS03_Setting.Tracking , 
         i_DB_PLT                    := #i_TRS03_DB_PLT , 
         i_Event_DB                  := "DB_Event_Section" , 
         i_Position_PEC_Update       := #s_TRS03.PEC_Position , 
         i_LPOS                      := #s_TRS03.LPOS , 
         i_Trigger_Send_Stat         := #i_Send_Statistics , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         o_ST_PEC_Miss               := #s_TRS03.ST_EOS_PEC_Miss
      );

// Hardware Layer - LMS Multispeed

      AN "M_Hardware_PN";
      JCN AC01;

      CALL #s_TRS03_FB_HW_MltSpd_LMS
      (  i_CMD_Send_Stat             := #i_Send_Statistics , 
         i_DB_PLT                    := #i_TRS03_DB_PLT , 
         i_Event_DB                  := "DB_Event_Section" , 
         i_Speed1                    := #i_TRS03_Setting.Hardware.Speed1 , 
         i_Speed1_Run_Out_Dist       := #i_TRS03_Setting.Hardware.Speed1_Run_Out_Dist , 
         i_Speed1_Start_Up_Dist      := #i_TRS03_Setting.Hardware.Speed1_Start_Up_Dist , 
         i_Speed2                    := #i_TRS03_Setting.Hardware.Speed2 , 
         i_Speed2_Run_Out_Dist       := #i_TRS03_Setting.Hardware.Speed2_Run_Out_Dist , 
         i_Speed2_Start_Up_Dist      := #i_TRS03_Setting.Hardware.Speed2_Start_Up_Dist , 
         i_CFG_Motor_Switch_Time     := 0 , //Not used
         i_CMD_Select_Speed          := 2 , 
         i_Available_IO              := #i_IO_Available , 
         i_LMS_NotPrsnt              := #i_TRS03_LMS_Not_Prsnt , 
         i_LMS_Error                 := #i_TRS03_LMS_Error , 
         i_IO_LMS_Auto               := #i_TRS03_IO_LMS_Auto , 
         i_IO_LMS_Healthy            := #i_TRS03_IO_LMS_Healthy , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         i_CMD_Req_Motor_Run         := #t_TRS03_Motor_Run , 
         o_IO_MTR_Fwd                := #o_TRS03_IO_MTR_Fwd , 
         o_IO_MTR_Rev                := #o_TRS03_IO_MTR_Rev , 
         o_IO_Speed_Select1          := #o_TRS03_IO_Speed_Select1 , 
         o_IO_Speed_Select2          := #o_TRS03_IO_Speed_Select2 , 
         o_ST_ASI_NotPrsnt           := #s_TRS03.ST_LMS_NotPrsnt , 
         o_ST_ASI_Err                := #s_TRS03.ST_LMS_Err , 
         o_ST_LMS_Not_Auto           := #s_TRS03.ST_LMS_Not_Auto , 
         o_ST_LMS_Not_Hthy           := #s_TRS03.ST_LMS_Not_Hthy , 
         o_Select_Conveyor_Speed     := #s_TRS03.Select_Conveyor_Speed , 
         o_Select_Run_Out_Dist       := #s_TRS03.Select_Run_Out_Dist , 
         o_Select_Started_Up_Dist    := #s_TRS03.Select_Started_Up_Dist
      );

      JU AC02;

AC01:      CALL #s_TRS03_FB_HW_MTR_PN_LMS
      (  i_CMD_Send_Stat             := #i_Send_Statistics , 
         i_DB_PLT                    := #i_TRS03_DB_PLT , 
         i_Event_DB                  := "DB_Event_Section" , 
         i_Speed                     := #i_TRS03_Setting.Hardware.Speed2 , 
         i_Run_Out_Dist              := #i_TRS03_Setting.Hardware.Speed2_Run_Out_Dist , 
         i_Start_Up_Dist             := #i_TRS03_Setting.Hardware.Speed2_Start_Up_Dist , 
         i_CFG_Motor_Switch_Time     := 0 , 
         i_CFG_In_Hardw_ID           := #i_TRS03_CFG_LMS_In_Hardw_ID , 
         i_CFG_Out_Hardw_ID          := #i_TRS03_CFG_LMS_Out_Hardw_ID , 
         i_Available_IO              := #i_IO_Available , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         i_CMD_Req_Motor_Run         := #t_TRS03_Motor_Run , 
         o_ST_FieldB_NotPrsnt        := #s_TRS03.ST_LMS_NotPrsnt , 
         o_ST_FieldB_Error           := #s_TRS03.ST_LMS_Err , 
         o_ST_LMS_Not_Auto           := #s_TRS03.ST_LMS_Not_Auto , 
         o_ST_LMS_Not_Hthy           := #s_TRS03.ST_LMS_Not_Hthy , 
         o_Select_Conveyor_Speed     := #s_TRS03.Select_Conveyor_Speed , 
         o_Select_Run_Out_Dist       := #s_TRS03.Select_Run_Out_Dist , 
         o_Select_Started_Up_Dist    := #s_TRS03.Select_Started_Up_Dist
      );

AC02:      NOP 0;

// Data Layer

      CALL #s_TRS03_FB_DAT_T
      (  i_ID                        := #i_TRS03_ID , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_DB_PLT_Lost_And_Found     := #i_DB_PLT_Lost_And_Found
      );

// Data Layer

      CALL #s_TRS03_FB_DAT
      (  i_ID_Section                := #i_TRS03_ID , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_PLC_Log_FIFO_DB           := "DB_LOG_Event_FIFO" , 
         i_CFG_BPI_Log_Level         := "DB_Setting".common.External_Log_Level , 
         i_CFG_PLC_Log_Level         := "DB_Setting".common.Internal_Log_Level , 
         i_CFG_PLC_Log_Route_Msgs    := FALSE
      );

NETWORK
TITLE = AD: Transport section TRS04
// TB08 - Twin Belt - LMS-V_1-dir_1-speed_PEC-EOS
      NOP 0;

// Create IO Available signal
      A #i_IO_Available;
      AN #s_TRS04.ST_LMS_NotPrsnt;
      AN #s_TRS04.ST_LMS_Err;
      = #t_TRS04_IO_Available;

// Equipment layer - PEC

      CALL #s_TRS04_FB_EQP_PEC_EOS
      (  i_Setting                   := #i_TRS04_Setting.PEC_1 , 
         i_DB_PLT                    := #i_TRS04_DB_PLT , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_Dwnstr_PLT_Pos            := 0 , 
         i_CFG_Blockage_Length       := #i_CFG_Blockage_Length , 
         i_CFG_Delay_On_Filter       := 15 , 
         i_CFG_Delay_Off_Filter      := 0 , 
         i_CFG_Flickering_Length     := 60 , 
         i_CFG_Min_Product_Length    := 60 , 
         i_CFG_Preset_PEC_Latch      := #s_TRS04.ST_LMS_Not_Auto , 
         i_CFG_Track_Present         := TRUE , 
         i_CFG_Reset_Block_PEC_Oc    := FALSE , 
         i_IO_NOT_PEC                := #i_TRS04_IO_NOT_EOS_PEC , 
         i_Eqp_Available_IO          := #t_TRS04_IO_Available , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         o_LPOS                      := #s_TRS04.LPOS , 
         o_PEC_Position              := #s_TRS04.PEC_Position , 
         o_ST_PEC_Blk                := #s_TRS04.ST_EOS_PEC_Blk
      );

// Condition to request stop
      A #s_TRS04.ST_LMS_NotPrsnt;
      O #s_TRS04.ST_LMS_Err;
      O #s_TRS04.ST_LMS_Not_Auto;
      O #s_TRS04.ST_LMS_Not_Hthy;
      O #s_TRS04.ST_EOS_PEC_Blk;
      O #s_TRS04.ST_EOS_PEC_Miss;
      O(;
      O #s_TRS01.Ext_Req_Stop;
      O #s_TRS02.Ext_Req_Stop;
      O #s_TRS03.Ext_Req_Stop;
      A #o_TRS04_ST_Started;
      );
      = #s_TRS04.Ext_Req_Stop;

// Equipment Layer - Basic

      CALL #s_TRS04_FB_EQP_Basic
      (  i_ID_Section                := #i_TRS04_ID , 
         i_Basic_Offset              := #i_TRS04_Setting.Basic.Offset , 
         i_DB_PLT                    := #i_TRS04_DB_PLT , 
         i_DB_PLT_DwnStr             := #i_TRS_Dwnstr_DB_PLT , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_Conveyor_Speed            := #s_TRS04.Select_Conveyor_Speed , 
         i_Run_Out_Distance          := #s_TRS04.Select_Run_Out_Dist , 
         i_Start_Up_Distance         := #s_TRS04.Select_Started_Up_Dist , 
         i_Minimum_Gap               := #i_TRS04_Setting.Basic.Minimum_Gap , 
         i_Add_Gap_Stop              := #i_TRS04_Setting.Basic.Add_Gap_Stop , 
         i_Minimum_H2H               := #i_TRS04_Setting.Basic.Minimum_H2H , 
         i_Add_H2H_Stop              := #i_TRS04_Setting.Basic.Add_H2H_Stop , 
         i_CFG_Cascade_Delay_Time    := 800 , 
         i_CFG_Strt_Up_T_E_Save      := 90 , 
         i_CFG_Run_Out_E_Save        := 20 , 
         i_CFG_Stop_T_E_Save         := 130 , 
         i_PPI_Displacement          := 0 , 
         i_Dwnstr_PLT_Pos            := #s_TRS04_FB_EQP_PEC_EOS.o_PEC_Position , 
         i_CFG_Disbl_E_Save          := "DB_Setting".common.Disable_Energy_Saving , 
         i_CFG_Slave_Mode            := FALSE , 
         i_CFG_Del_Window_Codes      := FALSE , 
         i_Available_IO              := #i_IO_Available , 
         i_Safety_OK                 := #i_Safety_OK , 
         i_CMD_Enable                := #i_CMD_Enable , 
         i_CMD_Start                 := #i_CMD_Start , 
         i_Ext_Req_Stop              := #s_TRS04.Ext_Req_Stop , 
         i_Ext_Req_Halt              := #t_Dwnstr_Not_RTR , 
         i_OS_Direction_Change       := FALSE , 
         i_Clr_PLT_Data              := #s_TRS04.ST_LMS_Not_Auto , 
         o_External                  := #o_TRS04_Ext_Outputs , 
         o_Motor_Run                 := #t_TRS04_Motor_Run , 
         o_ST_Items                  := #o_TRS04_ST_Items , 
         o_ST_Running                := #o_TRS04_ST_Running , 
         o_ST_Started                := #o_TRS04_ST_Started , 
         o_ST_Request_Halt           := #o_TRS04_ST_Req_Halt , 
         o_ST_Request_Stop           := #o_TRS04_ST_Req_Stop , 
         o_ST_External_Stop          := #o_TRS04_ST_Ext_Stop , 
         o_Ready_To_Restart          := #s_TRS04.Ready_To_Restart
      );

// Update Layer - TRK_Update

      CALL #s_TRS04_FB_TRK_Update_EOS
      (  i_Setting                   := #i_TRS04_Setting.Tracking , 
         i_DB_PLT                    := #i_TRS04_DB_PLT , 
         i_Event_DB                  := "DB_Event_Section" , 
         i_Position_PEC_Update       := #s_TRS04.PEC_Position , 
         i_LPOS                      := #s_TRS04.LPOS , 
         i_Trigger_Send_Stat         := #i_Send_Statistics , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         o_ST_PEC_Miss               := #s_TRS04.ST_EOS_PEC_Miss
      );

// Hardware Layer - LMS Multispeed

      AN "M_Hardware_PN";
      JCN AD01;

      CALL #s_TRS04_FB_HW_MltSpd_LMS
      (  i_CMD_Send_Stat             := #i_Send_Statistics , 
         i_DB_PLT                    := #i_TRS04_DB_PLT , 
         i_Event_DB                  := "DB_Event_Section" , 
         i_Speed1                    := #i_TRS04_Setting.Hardware.Speed1 , 
         i_Speed1_Run_Out_Dist       := #i_TRS04_Setting.Hardware.Speed1_Run_Out_Dist , 
         i_Speed1_Start_Up_Dist      := #i_TRS04_Setting.Hardware.Speed1_Start_Up_Dist , 
         i_Speed2                    := #i_TRS04_Setting.Hardware.Speed2 , 
         i_Speed2_Run_Out_Dist       := #i_TRS04_Setting.Hardware.Speed2_Run_Out_Dist , 
         i_Speed2_Start_Up_Dist      := #i_TRS04_Setting.Hardware.Speed2_Start_Up_Dist , 
         i_CFG_Motor_Switch_Time     := 0 , //Not used
         i_CMD_Select_Speed          := 2 , 
         i_Available_IO              := #i_IO_Available , 
         i_LMS_NotPrsnt              := #i_TRS04_LMS_Not_Prsnt , 
         i_LMS_Error                 := #i_TRS04_LMS_Error , 
         i_IO_LMS_Auto               := #i_TRS04_IO_LMS_Auto , 
         i_IO_LMS_Healthy            := #i_TRS04_IO_LMS_Healthy , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         i_CMD_Req_Motor_Run         := #t_TRS04_Motor_Run , 
         o_IO_MTR_Fwd                := #o_TRS04_IO_MTR_Fwd , 
         o_IO_MTR_Rev                := #o_TRS04_IO_MTR_Rev , 
         o_IO_Speed_Select1          := #o_TRS04_IO_Speed_Select1 , 
         o_IO_Speed_Select2          := #o_TRS04_IO_Speed_Select2 , 
         o_ST_ASI_NotPrsnt           := #s_TRS04.ST_LMS_NotPrsnt , 
         o_ST_ASI_Err                := #s_TRS04.ST_LMS_Err , 
         o_ST_LMS_Not_Auto           := #s_TRS04.ST_LMS_Not_Auto , 
         o_ST_LMS_Not_Hthy           := #s_TRS04.ST_LMS_Not_Hthy , 
         o_Select_Conveyor_Speed     := #s_TRS04.Select_Conveyor_Speed , 
         o_Select_Run_Out_Dist       := #s_TRS04.Select_Run_Out_Dist , 
         o_Select_Started_Up_Dist    := #s_TRS04.Select_Started_Up_Dist
      );

      JU AD02;

AD01:      CALL #s_TRS04_FB_HW_MTR_PN_LMS
      (  i_CMD_Send_Stat             := #i_Send_Statistics , 
         i_DB_PLT                    := #i_TRS04_DB_PLT , 
         i_Event_DB                  := "DB_Event_Section" , 
         i_Speed                     := #i_TRS04_Setting.Hardware.Speed2 , 
         i_Run_Out_Dist              := #i_TRS04_Setting.Hardware.Speed2_Run_Out_Dist , 
         i_Start_Up_Dist             := #i_TRS04_Setting.Hardware.Speed2_Start_Up_Dist , 
         i_CFG_Motor_Switch_Time     := 0 , 
         i_CFG_In_Hardw_ID           := #i_TRS04_CFG_LMS_In_Hardw_ID , 
         i_CFG_Out_Hardw_ID          := #i_TRS04_CFG_LMS_Out_Hardw_ID , 
         i_Available_IO              := #i_IO_Available , 
         i_CMD_Reset                 := #i_CMD_Reset , 
         i_CMD_Req_Motor_Run         := #t_TRS04_Motor_Run , 
         o_ST_FieldB_NotPrsnt        := #s_TRS04.ST_LMS_NotPrsnt , 
         o_ST_FieldB_Error           := #s_TRS04.ST_LMS_Err , 
         o_ST_LMS_Not_Auto           := #s_TRS04.ST_LMS_Not_Auto , 
         o_ST_LMS_Not_Hthy           := #s_TRS04.ST_LMS_Not_Hthy , 
         o_Select_Conveyor_Speed     := #s_TRS04.Select_Conveyor_Speed , 
         o_Select_Run_Out_Dist       := #s_TRS04.Select_Run_Out_Dist , 
         o_Select_Started_Up_Dist    := #s_TRS04.Select_Started_Up_Dist
      );

AD02:      NOP 0;

// Data Layer

      CALL #s_TRS04_FB_DAT_T
      (  i_ID                        := #i_TRS04_ID , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_DB_PLT_Lost_And_Found     := "DB_PLT_Lost_Found_T"
      );

// Data Layer

      CALL #s_TRS04_FB_DAT
      (  i_ID_Section                := #i_TRS04_ID , 
         i_DB_Event                  := "DB_Event_Section" , 
         i_PLC_Log_FIFO_DB           := "DB_LOG_Event_FIFO" , 
         i_CFG_BPI_Log_Level         := "DB_Setting".common.External_Log_Level , 
         i_CFG_PLC_Log_Level         := "DB_Setting".common.Internal_Log_Level , 
         i_CFG_PLC_Log_Route_Msgs    := FALSE
      );

NETWORK
TITLE = BA: Reset E-save downstream section
      AN #s_TRS04.Ext_Req_Stop;
      A #t_Dwnstr_Not_RTR;
      A(;
      O #s_TRS01_FB_EQP_Basic.o_ST_Items;
      O #s_TRS02_FB_EQP_Basic.o_ST_Items;
      O #s_TRS03_FB_EQP_Basic.o_ST_Items;
      O #s_TRS04_FB_EQP_Basic.o_ST_Items;
      O(;
      A #t_Item_at_Handover;// Item in handover of upstream
      A #i_CMD_Start;
      );
      );
      JCN BA99;

      OPN #i_TRS_Dwnstr_DB_PLT;
      L DBNO;
      T #t_DB_Num_PLT;

      CALL "FC_PLT_Srch_Inf_Dwn"
      (  i_DB_PLT_Num                := #t_DB_Num_PLT , 
         i_Position                  := 600 , 
         i_Window                    := 600 , 
         i_Info                      := -3 , 
         o_Position                  := #t_Not_Used , 
         o_Info                      := #t_Not_Used , 
         o_LNK                       := #t_Not_Used , 
         o_DB_PLT_Num                := #t_Not_Used , 
         o_Number_Items_Found        := #t_Num_Items_Found
      );

      L #t_Num_Items_Found;
      L 0;
      ==I;
      JCN BA99;

      CALL "FC_PLT_Write"
      (  i_DB_PLT_Num                := #t_DB_Num_PLT , 
         i_Position                  := 600 , 
         i_Info_State                := 0 , 
         i_Info_Physical             := -3 , 
         i_LNK                       := 0 , 
         i_DB_Event_Num              := 329
      );

BA99:      NOP 0;

NETWORK
TITLE = CA: Zone ouput
      NOP 0;

//Reset halt status for wrong report. ACZ in Die-Back if outfeed in Die-Back
      A #t_Dwnstr_Not_RTR;
      R #o_TRS01_ST_Req_Halt;
      R #o_TRS02_ST_Req_Halt;
      R #o_TRS03_ST_Req_Halt;
      R #o_TRS04_ST_Req_Halt;

// Zone output
      A #s_TRS01.ST_LMS_NotPrsnt;
      = #o_TRS01_ST_LMS_Not_Prsnt;
      A #s_TRS01.ST_LMS_Err;
      = #o_TRS01_ST_LMS_Error;
      A #s_TRS01.ST_LMS_Not_Auto;
      = #o_TRS01_ST_LMS_Not_Auto;
      A #s_TRS01.ST_LMS_Not_Hthy;
      = #o_TRS01_ST_LMS_Not_Hthy;
      A #s_TRS01.ST_EOS_PEC_Blk;
      = #o_TRS01_ST_EOS_PEC_Blk;
      A #s_TRS01.ST_EOS_PEC_Miss;
      = #o_TRS01_ST_EOS_PEC_Miss;

      A #s_TRS02.ST_LMS_NotPrsnt;
      = #o_TRS02_ST_LMS_Not_Prsnt;
      A #s_TRS02.ST_LMS_Err;
      = #o_TRS02_ST_LMS_Error;
      A #s_TRS02.ST_LMS_Not_Auto;
      = #o_TRS02_ST_LMS_Not_Auto;
      A #s_TRS02.ST_LMS_Not_Hthy;
      = #o_TRS02_ST_LMS_Not_Hthy;
      A #s_TRS02.ST_EOS_PEC_Blk;
      = #o_TRS02_ST_EOS_PEC_Blk;
      A #s_TRS02.ST_EOS_PEC_Miss;
      = #o_TRS02_ST_EOS_PEC_Miss;

      A #s_TRS03.ST_LMS_NotPrsnt;
      = #o_TRS03_ST_LMS_Not_Prsnt;
      A #s_TRS03.ST_LMS_Err;
      = #o_TRS03_ST_LMS_Error;
      A #s_TRS03.ST_LMS_Not_Auto;
      = #o_TRS03_ST_LMS_Not_Auto;
      A #s_TRS03.ST_LMS_Not_Hthy;
      = #o_TRS03_ST_LMS_Not_Hthy;
      A #s_TRS03.ST_EOS_PEC_Blk;
      = #o_TRS03_ST_EOS_PEC_Blk;
      A #s_TRS03.ST_EOS_PEC_Miss;
      = #o_TRS03_ST_EOS_PEC_Miss;

      A #s_TRS04.ST_LMS_NotPrsnt;
      = #o_TRS04_ST_LMS_Not_Prsnt;
      A #s_TRS04.ST_LMS_Err;
      = #o_TRS04_ST_LMS_Error;
      A #s_TRS04.ST_LMS_Not_Auto;
      = #o_TRS04_ST_LMS_Not_Auto;
      A #s_TRS04.ST_LMS_Not_Hthy;
      = #o_TRS04_ST_LMS_Not_Hthy;
      A #s_TRS04.ST_EOS_PEC_Blk;
      = #o_TRS04_ST_EOS_PEC_Blk;
      A #s_TRS04.ST_EOS_PEC_Miss;
      = #o_TRS04_ST_EOS_PEC_Miss;

// Ready to restart
      A #s_TRS01.Ready_To_Restart;
      A #s_TRS02.Ready_To_Restart;
      A #s_TRS03.Ready_To_Restart;
      A #s_TRS04.Ready_To_Restart;
      = #o_Ready_To_Restart;
      R %DBX10.3;//Reset cascade

END_FUNCTION_BLOCK


