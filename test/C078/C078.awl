      A #i_Dest_12_Available;
      FP #s_FP_Dest_12_Avail;
      R #o_Carrier_Assigned_12;

      JCN CONTINUE;
      A #i_Dest_13_Available;
      FP #s_FP_Dest_13_Avail;
      R #o_Carrier_Assigned_13;

      A #i_Dest_14_Available;
      FP #s_FP_Dest_14_Avail;
