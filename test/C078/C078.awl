      L #i_Destination_04;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_04;

      A(;
      L #s_Available_Destination;
      L #i_Destination_05;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_05;

      A(;
      L #s_Available_Destination;
      L #i_Destination_06;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_06;

      A(;
      L #s_Available_Destination;
      L #i_Destination_07;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_07;

      A(;
      L #s_Available_Destination;
      L #i_Destination_08;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_08;

      A(;
      L #s_Available_Destination;
      L #i_Destination_09;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_09;

      A(;
      L #s_Available_Destination;
      L #i_Destination_10;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_10;

      A(;
      L #s_Available_Destination;
      L #i_Destination_11;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_11;

      A(;
      L #s_Available_Destination;
      L #i_Destination_12;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_12;

      A(;
      L #s_Available_Destination;
      L #i_Destination_13;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_13;

      A(;
      L #s_Available_Destination;
      L #i_Destination_14;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_14;

      A(;
      L #s_Available_Destination;
      L #i_Destination_15;
      ==I;
      );
      A #t_Section_Item_At_HO;
      S #o_Carrier_Assigned_15;

FA01:      NOP 0;

// Reset assigned carriers when destination becomes available
      A #i_Dest_01_Available;
      FP #s_FP_Dest_01_Avail;
      R #o_Carrier_Assigned_01;

      A #i_Dest_02_Available;
      FP #s_FP_Dest_02_Avail;
      R #o_Carrier_Assigned_02;

      A #i_Dest_03_Available;
      FP #s_FP_Dest_03_Avail;
      R #o_Carrier_Assigned_03;

      A #i_Dest_04_Available;
      FP #s_FP_Dest_04_Avail;
      R #o_Carrier_Assigned_04;

      A #i_Dest_05_Available;
      FP #s_FP_Dest_05_Avail;
      R #o_Carrier_Assigned_05;

      A #i_Dest_06_Available;
      FP #s_FP_Dest_06_Avail;
      R #o_Carrier_Assigned_06;

      A #i_Dest_07_Available;
