   VAR_INPUT 
      i_Class_SBT : Bool;   // When TRUE tub class is SBT
      i_Class_OBT : Bool;   // When TRUE tub class is OBT
      i_ANY_Preferred_Dir : Any;   // ANY pointer to the preferred direction
